{
  "lexicon": 1,
  "id": "com.treeappreciation.tree",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "place": {
            "type": "string",
            "maxLength": 200,
            "description": "A nearby place label grounding the tree in the physical world, e.g. reverse-geocoded from coordinates"
          },
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "image": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg"],
            "maxSize": 1000000
          },
          "latitude": {
            "type": "string",
            "maxLength": 30
          },
          "longitude": {
            "type": "string",
            "maxLength": 30
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "photoTakenAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the photo was taken, from EXIF or manual entry"
          }
        }
      }
    }
  }
}
