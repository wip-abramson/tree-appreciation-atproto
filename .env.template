# Tree Appreciation — Environment Configuration
NODE_ENV="development"     # Options: 'development', 'production'
PORT="8080"                # The port your server will listen on
DB_PATH="./data/dev.db"     # The SQLite database path. Use "./data/dev.db" to persist across restarts, or ":memory:" for a temporary in-memory database.
# PUBLIC_URL=""            # Set when deployed publicly, e.g. "https://mysite.com". Informs OAuth client id.
# LOG_LEVEL="info"         # Options: 'fatal', 'error', 'warn', 'info', 'debug'
# MOCK_WRITES="true"       # Skip AT Protocol network writes (uploadBlob, putRecord, deleteRecord). Defaults to true in dev, false in production.
# BACKFILL_ON_BOOT="false" # Force a network backfill on boot even when the index already has data. Defaults to false — the server auto-backfills only when the index is empty (e.g. a fresh persistent volume).
# PDS_URL="https://my.pds" # The default PDS for login and sign-ups

# Secrets below *MUST* be set in production

# May be generated with `openssl rand -base64 33`
# COOKIE_SECRET=""

# May be generated with `./bin/gen-jwk` (requires `npm install` once first)
# PRIVATE_KEYS='[{"kty":"EC","kid":"123",...}]'
